{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "labels": ["dependencies"],
  "postUpdateOptions": ["gomodTidy"],
  "packageRules": [
    {
      "description": "Group Go module updates into a single PR.",
      "matchManagers": ["gomod"],
      "groupName": "go modules"
    },
    {
      "description": "Group GitHub Actions digest updates.",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump the SHA-pinned govulncheck in the Taskfile and workflows.",
      "managerFilePatterns": [
        "/^Taskfile\\.ya?ml$/",
        "/^\\.github/workflows/[^/]+\\.ya?ml$/"
      ],
      "matchStrings": [
        "govulncheck@(?<currentDigest>[a-f0-9]{40})[^#\\n]*#\\s*(?<currentValue>v[^\\s]+)"
      ],
      "depNameTemplate": "golang.org/x/vuln",
      "packageNameTemplate": "golang/vuln",
      "datasourceTemplate": "github-tags"
    }
  ]
}
